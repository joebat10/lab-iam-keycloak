OIDC_ISSUER=http://localhost:8080/realms/lab-iam
OIDC_CLIENT_ID=demo-spa
OIDC_REDIRECT_URI=http://localhost:3000/callback

# Nécessaire uniquement pour tester la route /introspect (RFC 7662),
# qui exige un client authentifié -- utilise le client confidentiel
# "demo-backend" créé en Phase 1 et son secret (onglet Credentials).
OIDC_INTROSPECTION_CLIENT_ID=demo-backend
OIDC_INTROSPECTION_CLIENT_SECRET=

SESSION_SECRET=change-me-session-secret
PORT=3000
